# ── App ────────────────────────────────
NODE_ENV=development
APP_NAME=nestjs-template
APP_PORT=3000
API_PREFIX=api/v1

# ── Database ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=template_db
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/template_db?schema=public

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changeme
DATABASE_NAME=template_db
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

# ── Admin Seed ─────────────────────────
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change_this_password

# ── JWT ────────────────────────────────
JWT_SECRET=super_secret_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ── Mail / SMTP ────────────────────────
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USER=user
MAIL_PASS=pass
